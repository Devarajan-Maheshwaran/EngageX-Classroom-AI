# Copy this to .env.local and fill in your local or ngrok backend URLs
# Use http://localhost:4000 and 4001 for purely local testing.
# If deploying to Vercel, use your ngrok URLs (e.g., https://abc-123.ngrok-free.app)
VITE_BACKEND_URL=http://localhost:4000
VITE_PYTHON_BACKEND_URL=http://localhost:4001
