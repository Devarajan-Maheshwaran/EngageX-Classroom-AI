PORT=4000
AGENT_CYCLE_SECS=15
SILENT_THRESHOLD_MINS=1
CONFUSION_WINDOW_SIZE=10
CONFUSION_MIN_HITS=3
CONFUSION_COOLDOWN_MINS=2
CONFUSION_NEG_THRESHOLD=0.72
IMBALANCE_THRESHOLD=0.35
MIN_ROOM_SIZE=2
BALANCER_EVERY_N=2

# Docker environment URLs (Internal routing inside docker network)
SUPABASE_URL=http://postgres:5432 # We will just pass the postgres connection string later, or mock it if supabase is not run. Wait, I should probably mock the supabase URL and key, or let the user supply their actual supabase instance if they want.
SUPABASE_KEY=mock-key-for-local
GROQ_API_KEY=your_groq_api_key_here
HF_API_KEY=your_hf_api_key_here

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://frontend:5173
VITE_BACKEND_URL=http://localhost:4000
