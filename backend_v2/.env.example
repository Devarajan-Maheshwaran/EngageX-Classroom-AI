# EngageX v2 Backend — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# ─── Supabase ────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Groq (free at console.groq.com) ─────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ─── Redis / Upstash (free tier) ─────────────────────────────
# Get from: upstash.com → Create Database → REST URL
REDIS_URL=redis://default:your-password@your-db.upstash.io:6379

# ─── Server config ───────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── Agent config ────────────────────────────────────────────
AGENT_CYCLE_SECS=30
CONFUSION_WINDOW_MINS=10
SILENT_THRESHOLD_MINS=3
CONFUSION_NEG_THRESHOLD=0.72
MAX_MSG_LEN=500
