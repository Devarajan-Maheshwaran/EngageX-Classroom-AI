FROM python:3.11-bullseye
WORKDIR /app
COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip pip install --default-timeout=1000 --retries=10 torch==2.2.2 --index-url https://download.pytorch.org/whl/cpu
RUN --mount=type=cache,target=/root/.cache/pip pip install --default-timeout=1000 --retries=10 --extra-index-url https://download.pytorch.org/whl/cpu -r requirements.txt
# Additional package for PDF generation
RUN --mount=type=cache,target=/root/.cache/pip pip install reportlab
COPY . .
EXPOSE 4001
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "4001"]
