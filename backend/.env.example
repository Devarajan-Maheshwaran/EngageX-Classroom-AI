# EngageX Backend — Environment Variables
# Copy to .env for local dev: cp .env.example .env

# Server
PORT=4000

# ─── Agent thresholds ─────────────────────────────────────────────────────────
# All have sane defaults. Override here for faster alerts during local testing.
# e.g. set SILENT_THRESHOLD_MINS=1 and AGENT_CYCLE_SECS=15 for quick demos.

SILENT_THRESHOLD_MINS=3
IMBALANCE_THRESHOLD=0.35
CONFUSION_WINDOW_SIZE=10
CONFUSION_MIN_HITS=3
CONFUSION_COOLDOWN_MINS=2
AGENT_CYCLE_SECS=60
MIN_ROOM_SIZE=2

# ─── HuggingFace Inference API (Phase 3B) ─────────────────────────────────────
# Used by mentorAgent to generate LLM-powered suggestions.
# Get a free key at: https://huggingface.co/settings/tokens
# Leave blank to use static fallback suggestions.
HF_API_KEY=
