# EngageX Backend — complete environment variable reference
# Phase 4B: all knobs documented in one place
# Copy to .env: cp .env.example .env

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ─── Input validation ──────────────────────────────────────────────────────────
# Max characters per participant message before it is rejected
MAX_MSG_LEN=500

# ─── Agent cycle ─────────────────────────────────────────────────────────────
# Master orchestrator cycle in seconds.
# Tip: set AGENT_CYCLE_SECS=15 locally for fast-firing alerts during friend tests.
AGENT_CYCLE_SECS=60

# Run the balancer check every N master cycles (reduces over-alerting).
BALANCER_EVERY_N=2

# ─── Monitor agent (silence detection) ───────────────────────────────────────
# Minutes of silence before a participant triggers a SILENT_PARTICIPANTS alert.
# Tip: set to 1 for quick demos; set to 15 for real classroom use.
SILENT_THRESHOLD_MINS=3

# ─── Balancer agent (participation imbalance) ───────────────────────────────
# Fraction of room that must have spoken to suppress the imbalance alert.
# e.g. 0.35 means alert if < 35% of participants have sent any message.
IMBALANCE_THRESHOLD=0.35

# Minimum room size before imbalance alerts are considered meaningful.
MIN_ROOM_SIZE=2

# ─── Confusion spike detector ──────────────────────────────────────────────
# How many recent messages to evaluate for the confusion spike window.
CONFUSION_WINDOW_SIZE=10

# Minimum number of confused/frustrated/negative hits in the window to trigger a spike.
CONFUSION_MIN_HITS=3

# Cooldown in minutes between successive confusion spike alerts for the same session.
CONFUSION_COOLDOWN_MINS=2

# Minimum negative sentiment score (0–1) to count a message as a confusion hit.
CONFUSION_NEG_THRESHOLD=0.72

# ─── MentorAgent / HuggingFace ──────────────────────────────────────────────
# HuggingFace Inference API key for LLM-powered mentor suggestions (Mistral-7B).
# Get a free key at: https://huggingface.co/settings/tokens
# Leave blank to use the curated static suggestion pools (always works, always fast).
HF_API_KEY=
