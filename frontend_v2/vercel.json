{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "@engagex_backend_url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.engagex.app/api/:path*"
    }
  ]
}
